# Integration test environment.
# Copy to tests/integration/.env (gitignored) and fill in values.
# Most match the Vercel Preview env keys for the project.

# --- Where the API is running ---
# `vercel dev` default. Use the deployed Preview URL to test against Vercel.
BASE_URL=http://localhost:3000

# --- Supabase (test/preview project) ---
SUPABASE_URL=https://your-project.supabase.co
# Service-role key (server-side). Used for direct DB inserts/cleanup over PostgREST.
SUPABASE_SECRET_KEY=eyJ...
# Anon/publishable key. Used only by the admin-login flow (test 16).
SUPABASE_PUBLISHABLE_KEY=eyJ...

# --- Stripe (TEST MODE keys only) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- API auth ---
PRODUCT_API_KEY=hex-string-from-vercel-env

# --- Admin user (must exist in Supabase auth.users; used by orders + tracking tests) ---
ADMIN_EMAIL=admin@example.test
ADMIN_PASSWORD=...

# --- Optional: where `stripe listen --forward-to` is pointing ---
# Only used in error messages to remind you to start the listener.
STRIPE_LISTEN_FORWARD_URL=http://localhost:3000/api/webhook
