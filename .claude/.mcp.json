{
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "web-browser-mcp-server": {
        "command": "npx",
        "args": [
          "-y",
          "@smithery/cli"
       ],
        "env": {
        "REQUEST_TIMEOUT": "30"
      }
    }
  }
}